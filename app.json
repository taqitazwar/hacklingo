{
  "expo": {
    "name": "Hacklingo",
    "slug": "hacklingo",
    "version": "1.0.0",
    "description": "Learn to code for free. Hacklingo teaches Python and more with bite-sized, gamified lessons guided by Bug the Ladybug — your personal coding companion.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E03232"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hacklingo.app",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use this to improve your learning experience.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hacklingo.app",
      "adaptiveIcon": {
        "backgroundColor": "#E03232",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-font"
    ]
  }
}
